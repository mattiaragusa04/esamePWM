/* Quick action Fedeltà — evidenziata in oro */
.profilo-action-fedelta {
  background: linear-gradient(135deg, #fef9e7, #fefce8) !important;
  border: 1.5px solid #fde68a !important;
}
.profilo-action-fedelta:hover {
  background: linear-gradient(135deg, #fde68a, #fef9e7) !important;
  border-color: #d4a017 !important;
}
.profilo-action-icon-gold {
  background: linear-gradient(135deg, #d4a017, #f4c430) !important;
  color: white !important;
}
